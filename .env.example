# Database
POSTGRES_DB=auditai
POSTGRES_USER=auditai
POSTGRES_PASSWORD=auditai
POSTGRES_PORT=5433

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# App ports
BACKEND_PORT=8080
FRONTEND_PORT=4200

# Spring datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/auditai
SPRING_DATASOURCE_USERNAME=auditai
SPRING_DATASOURCE_PASSWORD=auditai

# Spring rabbitmq
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# AI (LangChain4j + Gemini)
APP_AI_GEMINI_ENABLED=false
APP_AI_GEMINI_API_KEY=
APP_AI_GEMINI_MODEL=gemini-2.5-flash
APP_AI_GEMINI_TIMEOUT_MS=15000
APP_AI_GEMINI_TEMPERATURE=0.2
